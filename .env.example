# ═══════════════════════════════════════════════════════════
#  COPY THIS FILE TO .env AND CHANGE THE PASSWORDS
# ═══════════════════════════════════════════════════════════
#  .env is gitignored — NEVER commit real passwords to git.
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
#  LOCAL DEVELOPMENT DATABASES
# ═══════════════════════════════════════════════════════════

# PostgreSQL (local Docker container)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=ChangeMe123!
POSTGRES_DB=appdb

# SQL Server (local Docker container — optional)
MSSQL_SA_PASSWORD=ChangeMe123!
MSSQL_PID=Developer

# Redis (local Docker container)
REDIS_PASSWORD=ChangeMeRedis123!

# ═══════════════════════════════════════════════════════════
#  EXTERNAL DATABASE (Production / Existing Server)
# ═══════════════════════════════════════════════════════════
# Use docker-compose.external-db.yml when connecting to an
# existing PostgreSQL server instead of local Docker PostgreSQL.
# ═══════════════════════════════════════════════════════════

# Full Npgsql connection string for nopCommerce
# Example: Host=192.168.0.107;Port=5432;Database=arity_store_db;Username=postgres;Password=your_password;Pooling=true;
CONNECTION_STRING=Host=192.168.0.107;Port=5432;Database=arity_store_db;Username=postgres;Password=ChangeMePassword;Pooling=true;Trust Server Certificate=true;

# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# ═══════════════════════════════════════════════════════════
#  DOCKER REGISTRY (for pushing built images)
# ═══════════════════════════════════════════════════════════

# Your private Docker registry
REGISTRY=registry.arity.co.za
IMAGE_TAG=latest

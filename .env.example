#  COPY THIS FILE TO .env AND CHANGE THE PASSWORDS
# ═══════════════════════════════════════════════════════════
#  .env is gitignored — NEVER commit real passwords to git.
# ═══════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=ChangeMe123!
POSTGRES_DB=appdb

# SQL Server
MSSQL_SA_PASSWORD=ChangeMe123!
MSSQL_PID=Developer

# Redis
REDIS_PASSWORD=ChangeMeRedis123!

# nopCommerce Redis distributed cache (disabled during install to avoid SIGSEGV)
# After installation, uncomment in docker-compose.yml or set here:
# REDIS_CACHE_ENABLED=true
# REDIS_CACHE_TYPE=Redis
# REDIS_CONNECTION_STRING=db-infra-redis:6379,password=ChangeMeRedis123!,ssl=False
